{
    "name": "vto",
    "version": "1.0.0",
    "description": "Virtual Tournament Organizer - Automated bot that does everything a human TO can do",
    "type": "module",
    "scripts": {
        "dev": "pnpm tsx src/main.ts",
        "start": "pnpm tsx src/main.ts",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "lint": "biome lint src/",
        "lint:fix": "biome lint --write src/",
        "format": "biome format --write src/"
    },
    "dependencies": {
        "@discordx/importer": "^1.3.0",
        "better-sqlite3": "^11.0.0",
        "discord.js": "^14.22.1",
        "discordx": "^11.12.0",
        "drizzle-orm": "^0.40.0",
        "graphql-request": "^7.4.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.12",
        "@graphql-codegen/cli": "^6.3.1",
        "@graphql-codegen/typescript": "^5.0.10",
        "@graphql-codegen/typescript-resolvers": "^5.1.8",
        "@types/better-sqlite3": "^7.0.0",
        "@types/node": "^20.0.0",
        "dotenv": "^17.4.2",
        "drizzle-kit": "^0.30.0",
        "tsx": "^4.7.0",
        "typescript": "^5.4.0"
    }
}
